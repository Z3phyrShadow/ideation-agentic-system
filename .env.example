# Required environment variables for the Discord AI assistant.
# Copy this file to .env and fill in your values.

# Discord bot token from the Discord Developer Portal.
# https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Google Generative AI API key.
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# The Discord channel ID of your #ideas channel.
# The bot will automatically create a thread on every message posted there.
# Right-click the channel in Discord (with Developer Mode on) and select "Copy Channel ID".
AGENT_CHANNEL_ID=your_ideas_channel_id_here

# Tavily API key for web search (https://app.tavily.com).
TAVILY_API_KEY=your_tavily_api_key_here

# The Discord channel ID of your #career channel.
# Drop a resume PDF here with your target role to get a skill gap report + project suggestions.
# Right-click the channel in Discord (with Developer Mode on) and select "Copy Channel ID".
CAREER_CHANNEL_ID=your_career_channel_id_here
